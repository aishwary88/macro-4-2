# ========================================
# Traffic Analyzer Configuration
# ========================================

# Database
DATABASE_URL=sqlite:///./traffic_analyzer.db

# Models
YOLO_MODEL_PATH=models/yolov8n.pt

# Speed Settings
SPEED_LIMIT_KMH=60
ROI_DISTANCE_METERS=10
ROI_LINE_A_Y=300
ROI_LINE_B_Y=500

# Detection
DETECTION_CONFIDENCE=0.25
OCR_CONFIDENCE=0.4

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Paths
INPUT_DIR=input
OUTPUT_DIR=output
MODELS_DIR=models
LOGS_DIR=logs

# Processing
ANPR_FRAME_INTERVAL=10
MAX_TRACK_AGE=30
CAMERA_FPS=60
CAMERA_FRAME_SKIP=0
