# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Environment / secrets ──────────────────────────────────────
.env
.env.*
*.env

# ── Database (runtime data, not source) ───────────────────────
traffic_analyzer.db
*.db
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log

# ── Output files (generated at runtime) ───────────────────────
output/

# ── Input videos (large binary files) ─────────────────────────
input/
*.mp4
*.avi
*.mov
*.mkv
*.webm

# ── Dataset (generated by prepare_dataset.py) ─────────────────
dataset/

# ── Training runs (large model weights + artifacts) ───────────
# Keep: results.csv, args.yaml (small, useful for reference)
# Ignore: weights (large .pt files), batch images, cache files
runs/detect/*/weights/last.pt
runs/detect/*/weights/*.pt
!runs/detect/models/plate_detector/weights/best.pt
runs/detect/*/*.jpg
runs/detect/*/*.png
runs/detect/*/*.cache
runs/detect/**/*.cache
runs/detect/**/labels.cache

# ── Google images dataset (raw, large) ────────────────────────
google_images/

# ── Video images (extracted frames) ───────────────────────────
video_images/

# ── State-wise OLX data ────────────────────────────────────────
State-wise_OLX/

# ── Test videos in root (duplicates of input/) ────────────────
test_video.mp4
test_video_3.mp4
test_video_4.mp4

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Pytest cache ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
